# QuickLink Backend .env Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/quicklink

# ============================================
# JWT AUTHENTICATION
# ============================================
# Secret key for signing JWT tokens
# IMPORTANT: Use a strong, random string in production
# Generate one: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-in-production

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port the backend server will run on
PORT=3001

# Node environment (development, production, test)
NODE_ENV=development

# ============================================
# API CONFIGURATION
# ============================================
# Base URL for shortened links (used in redirect links)
BASE_URL=http://localhost:3001

# Frontend URL (for CORS access from React app)
CLIENT_URL=http://localhost:5173

